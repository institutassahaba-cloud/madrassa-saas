generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── MULTI-TENANT ────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  email     String?
  phone     String?
  address   String?
  city      String?
  country   String   @default("FR")
  currency  String   @default("EUR")
  timezone  String   @default("Europe/Paris")
  isActive  Boolean  @default(true)
  plan      String   @default("STARTER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  students      Student[]
  groups        Group[]
  payments      Payment[]
  assessments   Assessment[]
  attendances   Attendance[]
  salaries      TeacherSalary[]
  notifications Notification[]
  settings      TenantSettings?
}

model TenantSettings {
  id                  String  @id @default(cuid())
  tenantId            String  @unique
  tenant              Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wiseMerchantToken   String?
  paypalClientId      String?
  paypalClientSecret  String?
  gmailRefreshToken   String?
  whatsappApiKey      String?
  whatsappPhoneNumber String?
  smtpHost            String?
  smtpPort            Int?
  smtpUser            String?
  smtpPassword        String?
  smtpFrom            String?
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  email         String
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("SECRETARY")
  isActive      Boolean   @default(true)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  teacherGroups Group[]         @relation("TeacherGroups")
  attendances   Attendance[]    @relation("TeacherAttendances")
  assessments   Assessment[]    @relation("TeacherAssessments")
  salaries      TeacherSalary[]

  @@unique([tenantId, email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── STUDENTS ────────────────────────────────────────────────────────────────

model Student {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  gender         String
  dateOfBirth    DateTime?
  phone          String?
  email          String?
  address        String?
  city           String?
  enrollmentDate DateTime  @default(now())
  groupId        String?
  group          Group?    @relation(fields: [groupId], references: [id])
  level          String?
  monthlyFee     Float     @default(0)
  status         String    @default("ACTIVE")
  notes          String?
  parentName     String?
  parentPhone    String?
  parentEmail    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  payments    Payment[]
  attendances Attendance[]
  grades      Grade[]
}

// ─── GROUPS ──────────────────────────────────────────────────────────────────

model Group {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  level       String?
  teacherId   String?
  teacher     User?    @relation("TeacherGroups", fields: [teacherId], references: [id])
  schedule    String?
  maxStudents Int      @default(30)
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students    Student[]
  attendances Attendance[]
  assessments Assessment[]
}

// ─── PAYMENTS ────────────────────────────────────────────────────────────────

model Payment {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id])
  amount        Float
  dueDate       DateTime
  paidDate      DateTime?
  status        String    @default("PENDING")
  method        String?
  reference     String?
  month         Int
  year          Int
  notes         String?
  invoiceNumber String?
  source        String    @default("MANUAL")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── ATTENDANCE ──────────────────────────────────────────────────────────────

model Attendance {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id])
  teacherId String?
  teacher   User?    @relation("TeacherAttendances", fields: [teacherId], references: [id])
  date      DateTime
  status    String
  note      String?
  createdAt DateTime @default(now())

  @@unique([studentId, groupId, date])
}

// ─── ASSESSMENTS & GRADES ────────────────────────────────────────────────────

model Assessment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id])
  teacherId   String?
  teacher     User?    @relation("TeacherAssessments", fields: [teacherId], references: [id])
  title       String
  subject     String?
  date        DateTime
  maxScore    Float    @default(20)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  grades Grade[]
}

model Grade {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])
  score        Float?
  observation  String?
  createdAt    DateTime   @default(now())

  @@unique([assessmentId, studentId])
}

// ─── SALARIES ────────────────────────────────────────────────────────────────

model TeacherSalary {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     User      @relation(fields: [teacherId], references: [id])
  month       Int
  year        Int
  hourlyRate  Float?
  fixedSalary Float?
  hoursWorked Float?
  totalAmount Float
  status      String    @default("PENDING")
  paidDate    DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([teacherId, month, year])
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  recipient String?
  channel   String
  status    String   @default("PENDING")
  sentAt    DateTime?
  createdAt DateTime @default(now())
}

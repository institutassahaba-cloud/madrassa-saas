generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── MULTI-TENANT ────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  email     String?
  phone     String?
  address   String?
  city      String?
  country   String   @default("FR")
  currency  String   @default("EUR")
  timezone  String   @default("Europe/Paris")
  isActive  Boolean  @default(true)
  plan      String   @default("STARTER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  students             Student[]
  groups               Group[]
  payments             Payment[]
  assessments          Assessment[]
  attendances          Attendance[]
  salaries             TeacherSalary[]
  notifications        Notification[]
  settings             TenantSettings?
  lessonSessions       LessonSession[]
  lessons              Lesson[]
  timeSlots            TimeSlot[]
  paymentMatches       PaymentMatch[]
  paymentAliases       PaymentAlias[]
  directorPayerAliases DirectorPayerAlias[]
  secretaryCommissions SecretaryCommission[]
  teacherContracts     TeacherContract[]
  books                Book[]
  examFiles            ExamFile[]
}

model TenantSettings {
  id                  String  @id @default(cuid())
  tenantId            String  @unique
  tenant              Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wiseMerchantToken   String?
  paypalClientId      String?
  paypalClientSecret  String?
  gmailRefreshToken   String?
  paymentScanEnabled  Boolean @default(false)
  paymentScanStartedAt DateTime?
  paymentScanLastRunAt DateTime? // dernier passage du scan (cron)
  paymentScanLastError String?   // dernière erreur (ex: Gmail invalid_grant), null si OK
  googleContactsRefreshToken String?
  googleContactsEmail String?
  whatsappApiKey      String?
  whatsappPhoneNumber String?
  smtpHost            String?
  smtpPort            Int?
  smtpUser            String?
  smtpPassword        String?
  smtpFrom            String?
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  email         String
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("SECRETARY")
  isActive      Boolean   @default(true)
  phone         String?
  timezone      String    @default("Europe/Paris")
  mustChangePassword Boolean @default(false)
  contactEmail  String?
  hasOnboarded  Boolean   @default(false)
  individualRate Float?
  binomeRate     Float?
  groupRate      Float?
  paymentInfo    String?
  meetingLink    String?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  teacherGroups   Group[]         @relation("TeacherGroups")
  attendances     Attendance[]    @relation("TeacherAttendances")
  assessments     Assessment[]    @relation("TeacherAssessments")
  salaries        TeacherSalary[]
  teacherSessions LessonSession[] @relation("TeacherSessions")
  timeSlots       TimeSlot[]
  contracts       TeacherContract[]

  @@unique([tenantId, email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── STUDENTS ────────────────────────────────────────────────────────────────

model Student {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  displayName    String? // nom brut tel qu'écrit dans les Sheets (mononyme possible)
  legacyId       String? // ancien ID Google (EL###) pour traçabilité migration
  gender         String? // optionnel : les données Google n'ont pas de genre
  dateOfBirth    DateTime?
  phone          String?
  email          String?
  address        String?
  city           String?
  enrollmentDate DateTime  @default(now())
  groupId        String?
  group          Group?    @relation(fields: [groupId], references: [id])
  level          String?
  subject        String?
  monthlyFee     Float     @default(0)
  // ── Facturation (col M des Sheets) ──
  payerName      String? // nom du payeur attendu (parent/virement)
  paymentType    String? // "PAYPAL" | "WISE"
  paymentGraceAllowed Boolean @default(false) // cours autorisé malgré retard/absence de paiement
  hourlyRate     Float? // tarif horaire
  lessonsPerWeek Int? // nombre de cours par semaine
  duration       String? // durée d'un cours ("30 min", "1h")
  googleContactResourceName String?
  status         String    @default("ACTIVE") // ACTIVE | PAUSED | STOPPED
  recontactDate  DateTime?
  notes          String?
  parentName     String?
  parentPhone    String?
  parentEmail    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  payments       Payment[]
  attendances    Attendance[]
  grades         Grade[]
  lessonSessions LessonSession[]
  paymentMatches PaymentMatch[]
  paymentAliases PaymentAlias[]

  @@index([tenantId, legacyId])
}

model PaymentAlias {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type       String   @default("ANY") // PAYPAL | WISE | ANY si mode non forcé
  alias      String
  normalized String
  source     String    @default("MANUAL") // TDB | MANUAL
  confidence String    @default("EXACT") // EXACT | ALTERNATIVE | LABEL
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([tenantId, studentId, type, normalized])
  @@index([tenantId, normalized])
  @@index([tenantId, type])
}

// Payeurs identifiés comme étant pour le directeur (pas un élève) : virements
// personnels (ex: épouse, fille...) reçus sur la même boîte de facturation.
// Appris manuellement une fois, puis reconnus automatiquement au scan suivant.
model DirectorPayerAlias {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type       String    @default("ANY") // PAYPAL | WISE | ANY
  alias      String
  normalized String
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([tenantId, type, normalized])
  @@index([tenantId, normalized])
}

// ─── SCHEDULE ────────────────────────────────────────────────────────────────

model TimeSlot {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id])
  dayOfWeek Int // 0=Dim 1=Lun 2=Mar 3=Mer 4=Jeu 5=Ven 6=Sam
  startTime String // "09:00"
  endTime   String // "09:30"
  label     String?
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exceptions SlotException[]
}

model SlotException {
  id        String   @id @default(cuid())
  slotId    String
  slot      TimeSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  date      DateTime // la date précise annulée (YYYY-MM-DD)
  reason    String?
  createdAt DateTime @default(now())

  @@unique([slotId, date])
}

// ─── LESSON SESSIONS ─────────────────────────────────────────────────────────

model LessonSession {
  id                 String    @id @default(cuid())
  tenantId           String
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId          String
  student            Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacherId          String
  teacher            User      @relation("TeacherSessions", fields: [teacherId], references: [id])
  subject            String
  number             Int
  frequency          Int?
  duration           String?
  isComplete         Boolean   @default(false)
  // ── Cycle « fin de session » → demande de paiement ──
  endedAt            DateTime? // case « Fin de session » cochée / dernier cours fait
  paymentRequestedAt DateTime? // email de demande envoyé
  reminderAt         DateTime? // relance envoyée
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  lessons  Lesson[]
  payments Payment[]

  @@unique([studentId, subject, number])
}

model Lesson {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessionId String
  session   LessonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  number    Int
  date      DateTime?
  status          String        @default("PENDING")
  content         String?
  duration        Int?          // durée réelle en minutes (null = durée prévue)
  makeupMinutes   Int?          // minutes à rattraper sur un autre cours
  makeupOnLessonId String?      // id du cours sur lequel rattraper
  legacyPayrollBoundary Boolean @default(false) // dernier cours déjà comptabilisé dans l'ancien système
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// ─── GROUPS ──────────────────────────────────────────────────────────────────

model Group {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  level       String?
  teacherId   String?
  teacher     User?    @relation("TeacherGroups", fields: [teacherId], references: [id])
  schedule    String?
  maxStudents Int      @default(30)
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students    Student[]
  attendances Attendance[]
  assessments Assessment[]
  timeSlots   TimeSlot[]
}

// ─── PAYMENTS ────────────────────────────────────────────────────────────────

model Payment {
  id                String         @id @default(cuid())
  tenantId          String
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId         String
  student           Student        @relation(fields: [studentId], references: [id])
  amount            Float
  dueDate           DateTime
  paidDate          DateTime?
  // Cycle de vie : EXPECTED → EMAIL_SENT → REMINDED → MATCHED → CONFIRMED → REJECTED (+ PENDING/PAID legacy)
  status            String         @default("PENDING")
  method            String?
  reference         String?
  month             Int
  year              Int
  notes             String?
  invoiceNumber     String?
  source            String         @default("MANUAL") // MANUAL | PAYPAL | WISE
  // ── Lien session + machine à états de matching ──
  lessonSessionId   String?
  lessonSession     LessonSession? @relation(fields: [lessonSessionId], references: [id])
  sessionNumber     Int?
  expectedAmount    Float?
  receivedAmount    Float?
  expectedPayerName String?
  detectedPayerName String?
  emailSentAt       DateTime?
  confirmedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  allocations PaymentAllocation[]
}

// ─── ATTENDANCE ──────────────────────────────────────────────────────────────

model Attendance {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id])
  teacherId String?
  teacher   User?    @relation("TeacherAttendances", fields: [teacherId], references: [id])
  date      DateTime
  status    String
  note      String?
  createdAt DateTime @default(now())

  @@unique([studentId, groupId, date])
}

// ─── ASSESSMENTS & GRADES ────────────────────────────────────────────────────

model Assessment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id])
  teacherId   String?
  teacher     User?    @relation("TeacherAssessments", fields: [teacherId], references: [id])
  title       String
  subject     String?
  date        DateTime
  maxScore    Float    @default(20)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  grades Grade[]
}

model Grade {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])
  score        Float?
  observation  String?
  createdAt    DateTime   @default(now())

  @@unique([assessmentId, studentId])
}

// ─── SALARIES ────────────────────────────────────────────────────────────────

model TeacherSalary {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacherId    String
  teacher      User      @relation(fields: [teacherId], references: [id])
  month        Int
  year         Int
  hourlyRate   Float?
  fixedSalary  Float?
  hoursWorked  Float?
  lessonsCount Int? // nb de cours réellement donnés sur la période
  periodStart  DateTime? // borne mensuelle (marqueur couleur dans les Sheets)
  periodEnd    DateTime?
  totalAmount  Float
  status       String    @default("PENDING")
  paidDate     DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([teacherId, month, year])
}

// ─── PAYMENT MATCHING (parsing email PayPal/Wise) ────────────────────────────
// Un email de paiement détecté = un événement consommé UNE SEULE FOIS.
model PaymentMatch {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  source            String // PAYPAL | WISE
  gmailMessageId    String // verrou unique : transaction PayPal / transfert Wise / référence bancaire
  receivedAmount    Float
  detectedPayerName String?
  paymentLabel      String? // libellé / note du paiement, utile pour fratrie ou multi-profs
  paymentDate       DateTime?
  // Élève « pressenti » (facultatif, indicatif)
  studentId         String?
  student           Student?  @relation(fields: [studentId], references: [id])
  // TO_VERIFY | CONFIRMED | REJECTED | AUTO_CONFIRMED
  status            String    @default("TO_VERIFY")
  score             Float?
  reason            String? // pourquoi non auto-validé (montant ≠, nom faible, ambigu, groupé…)
  rawSubject        String?
  confirmedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  allocations PaymentAllocation[]

  @@unique([tenantId, gmailMessageId])
  @@index([tenantId, status])
}

// Allocation N-N : un email (PaymentMatch) peut couvrir plusieurs Payment
// (fratrie, 2 sessions). Total alloué ≤ montant reçu.
model PaymentAllocation {
  id             String       @id @default(cuid())
  paymentMatchId String
  paymentMatch   PaymentMatch @relation(fields: [paymentMatchId], references: [id], onDelete: Cascade)
  paymentId      String
  payment        Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  amount         Float // part allouée à ce Payment
  createdAt      DateTime     @default(now())

  @@unique([paymentMatchId, paymentId])
}

// ─── COMMISSION SECRÉTAIRE (10 % des paiements encaissés) ────────────────────
// Visible directeur uniquement.
model SecretaryCommission {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  secretaryId    String
  month          Int
  year           Int
  collectedTotal Float // total encaissé sur la période
  rate           Float     @default(0.10)
  amount         Float // = collectedTotal * rate
  status         String    @default("PENDING")
  paidDate       DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([secretaryId, month, year])
}

// ─── LIVRES DE L'INSTITUT ────────────────────────────────────────────────────
model Book {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  description String?
  fileUrl     String? // PDF (Drive ou stockage)
  coverUrl    String?
  level       String?
  subject     String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── CONTRATS ────────────────────────────────────────────────────────────────

model TeacherContract {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     User     @relation(fields: [teacherId], references: [id])
  title       String
  driveFileId String
  driveUrl    String
  uploadedAt  DateTime @default(now())
}

// ─── CONTRÔLES (fichiers uploadés, classés par niveau) ───────────────────────
model ExamFile {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String
  level     String
  fileName  String
  fileUrl   String
  fileSize  Int?
  uploadedBy String?
  createdAt DateTime @default(now())

  @@index([tenantId, level])
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  recipient String?
  channel   String
  status    String    @default("PENDING")
  sentAt    DateTime?
  createdAt DateTime  @default(now())
}
